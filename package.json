{
  "name": "reswob-spreadsheet-viewer",
  "displayName": "Spreadsheet Studio by Reswob",
  "description": "Open, view, edit, sort, and search CSV, Excel (.xlsx/.xls), LibreOffice (.ods), and Google Sheets files directly in VS Code.",
  "version": "1.0.0",
  "publisher": "CharlieGitDB",
  "author": {
    "name": "CharlieGitDB",
    "email": "charliedevelopmentaccess@gmail.com"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CharlieGitDB/reswob-spreadsheet-viewer"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "spreadsheet",
    "csv",
    "excel",
    "xlsx",
    "ods",
    "libreoffice",
    "google sheets",
    "viewer",
    "editor",
    "table"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "reswob.spreadsheetEditor",
        "displayName": "Reswob Spreadsheet Editor",
        "selector": [
          {
            "filenamePattern": "*.csv"
          },
          {
            "filenamePattern": "*.tsv"
          },
          {
            "filenamePattern": "*.xlsx"
          },
          {
            "filenamePattern": "*.xls"
          },
          {
            "filenamePattern": "*.ods"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "reswob.openSpreadsheet",
        "title": "Reswob: Open Spreadsheet"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --sourcemap",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
